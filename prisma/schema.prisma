// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model CoachUser {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String   // hashed with PBKDF2-SHA256
  name      String?
  createdAt DateTime @default(now())
}

model Swimmer {
  id        String   @id @default(cuid())
  name      String
  group     String
  status    String
  readiness Int      @default(100)
  username  String   @unique
  password  String
  gender    String?  // "male" | "female"
  
  // Gamification — XP Dual-Track System
  xp            Int?     // Legacy field, kept for backward compat
  totalXp       Int      @default(0)   // Only increases. Used for level calculation
  balance       Int      @default(0)   // Spendable currency. Decreases on purchase
  level         Int?     // Auto-calculated from totalXp
  currentStreak Int?     // Consecutive training-day check-ins
  lastCheckIn   String?  // ISO date of last check-in
  
  // Avatar & Shop
  inventory     Json?    // Array of purchased ShopItem IDs
  equippedItems Json?    // {head: "id", eyes: "id", body: "id", lower: "id", feet: "id", hand: "id", background: "id"}
  wishlist      Json?    // Array of up to 3 ShopItem IDs
  
  // Data Profile
  mainStroke         String?
  bestTimes          Json?
  injuries           Json?
  injuryNote         String?
  injuryBodyMap      Json?    // {"leftShoulder": 5, "lowerBack": 3, ...} from Body Map
  lastProfileUpdate  String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  feedbacks         Feedback[]
  attendance        AttendanceRecord[]
  performances      PerformanceRecord[]
  blockFeedbacks    BlockFeedback[]
  weeklyFeedbacks   WeeklyFeedback[]
  dailyFeedbacks    DailyFeedback[]
  targetedFeedbacks TargetedFeedback[]
  xpTransactions    XpTransaction[]
  buddyPairsAs1     BuddyPair[]     @relation("BuddySwimmer1")
  buddyPairsAs2     BuddyPair[]     @relation("BuddySwimmer2")
  activityFeed      ActivityFeedItem[]
}

model TrainingPlan {
  id            String   @id @default(cuid())
  date          String
  startTime     String?
  endTime       String?
  group         String
  blocks        Json     // TrainingBlock[]
  totalDistance Int
  focus         String
  status        String
  coachNotes    String?
  targetedNotes Json?    // Record<string, string>
  imageUrl      String?  // URL of the uploaded plan photo
  analysis      PlanAnalysis?
  isStarred     Boolean  @default(false)
  trainingType  String?  // "aerobic"|"anaerobic"|"lactate"|"sprint"|"recovery"|"relaxation"|"strength"|"endurance"|"race_prep"
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([date])
  @@index([group])
}

model Feedback {
  id        String   @id @default(cuid())
  swimmerId String
  planId    String
  date      String
  rpe       Int
  soreness  Int
  comments  String
  timestamp String
  goodPoints        String?
  improvementAreas  String?

  createdAt DateTime @default(now())

  swimmer Swimmer @relation(fields: [swimmerId], references: [id], onDelete: Cascade)

  @@unique([swimmerId, date])
  @@index([swimmerId])
  @@index([date])
}

model AttendanceRecord {
  id        String   @id @default(cuid())
  date      String
  swimmerId String
  status    String
  timestamp String
  
  createdAt DateTime @default(now())
  
  swimmer Swimmer @relation(fields: [swimmerId], references: [id], onDelete: Cascade)
  
  @@index([date])
  @@index([swimmerId])
}

model PerformanceRecord {
  id          String   @id @default(cuid())
  swimmerId   String
  event       String
  time        String
  date        String
  isPB        Boolean  @default(false)
  improvement Float?
  meetName    String?
  notes       String?
  
  createdAt DateTime @default(now())
  
  swimmer Swimmer @relation(fields: [swimmerId], references: [id], onDelete: Cascade)
  
  @@index([swimmerId])
  @@index([date])
}

model BlockTemplate {
  id         String   @id @default(cuid())
  templateId String   @unique
  name       String
  category   String
  type       String
  rounds     Int
  items      Json     // PlanItem[]
  note       String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([category])
}

model PlanAnalysis {
  id             String   @id @default(cuid())
  planId         String   @unique
  imageUrl       String
  rawText        String?  // OCR raw text
  structuredData Json?    // Parsed blocks and sets
  coachInsights  Json?    // Detected patterns (e.g. "Likes 400 IM warmup")
  aiSuggestions  Json?    // Suggestions given by AI
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  plan           TrainingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
}

// Block-level feedback from athletes
model BlockFeedback {
  id        String   @id @default(cuid())
  planId    String
  blockId   String   // ID of the training block within the plan
  swimmerId String
  reaction  String?  // 'like' | 'dislike' | null
  comment   String?  // Text comment from athlete
  tags      String[] // e.g. ["Too Tight", "Shoulder Pain"]
  
  createdAt DateTime @default(now())
  
  swimmer   Swimmer  @relation(fields: [swimmerId], references: [id], onDelete: Cascade)
  
  @@index([planId])
  @@index([blockId])
  @@index([swimmerId])
  @@unique([planId, blockId, swimmerId])
}

// ==========================================
// Weekly Training & Feedback System
// ==========================================

// Weekly training plan (folder of daily sessions)
model WeeklyPlan {
  id          String   @id @default(cuid())
  weekStart   String   // Monday date YYYY-MM-DD
  weekEnd     String   // Sunday date YYYY-MM-DD
  group       String   // Legacy: hardcoded "Advanced", kept for backward compat
  title       String?  // e.g. "第12周训练"
  coachNotes  String?
  isPublished Boolean  @default(false)
  targetGroup Json?    // Array of GroupLevel strings (e.g. ["Junior", "Intermediate"]) — null + no individual = all athletes
  targetSwimmerIds Json? // Array of swimmer IDs for individual targeting
  overviewImageUrl String?   // R2 URL for weekly overview photo
  overviewContentHtml String? // HTML for weekly overview rich text notes

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sessions    DailySession[]
  feedbacks   WeeklyFeedback[]

  @@index([weekStart])
  @@index([group])
}

// Daily session within a weekly plan (photo + annotation)
model DailySession {
  id            String   @id @default(cuid())
  weeklyPlanId  String
  label         String   // e.g. "周三", "周六上午", "周六下午"
  date          String   // YYYY-MM-DD
  imageData     String?  // Base64 encoded image data (legacy)
  imageType     String?  // MIME type e.g. "image/jpeg" (legacy)
  notes         String?
  sortOrder     Int      @default(0)

  // Flexible content
  contentBlocks Json?    // Array<{type: "text"|"image"|"video"|"link", content: string, thumbnailUrl?: string}>
  contentHtml   String?  // HTML from WYSIWYG editor
  editorMode    String   @default("legacy")  // "block" | "rich" | "legacy"

  createdAt     DateTime @default(now())

  weeklyPlan    WeeklyPlan @relation(fields: [weeklyPlanId], references: [id], onDelete: Cascade)

  @@index([weeklyPlanId])
  @@index([date])
}

// Athlete weekly feedback (big feedback containing daily sub-feedbacks)
model WeeklyFeedback {
  id            String   @id @default(cuid())
  swimmerId     String
  weeklyPlanId  String?  // Optional link to weekly plan
  weekStart     String   // Monday date YYYY-MM-DD
  summary       String?  // Overall weekly summary text
  isSubmitted   Boolean  @default(false)
  submittedAt   String?  // ISO date when submitted
  coachReply    String?  // Coach's reply to the weekly summary
  repliedAt     String?  // ISO date when coach replied
  isReplied     Boolean  @default(false)
  readAt        DateTime? // When the coach read the feedback
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  swimmer       Swimmer  @relation(fields: [swimmerId], references: [id], onDelete: Cascade)
  weeklyPlan    WeeklyPlan? @relation(fields: [weeklyPlanId], references: [id], onDelete: SetNull)
  dailyFeedbacks DailyFeedback[]
  
  @@index([swimmerId])
  @@index([weekStart])
  @@unique([swimmerId, weekStart])
}

// Daily sub-feedback within a weekly feedback
model DailyFeedback {
  id               String   @id @default(cuid())
  weeklyFeedbackId String
  swimmerId        String   // Added for robust identification
  date             String   // YYYY-MM-DD
  rpe              Int?     // 1-10 fatigue
  soreness         Int?     // 1-10 soreness
  reflection       String?  // Free text
  
  createdAt        DateTime @default(now())
  
  weeklyFeedback   WeeklyFeedback @relation(fields: [weeklyFeedbackId], references: [id], onDelete: Cascade)
  swimmer          Swimmer  @relation(fields: [swimmerId], references: [id], onDelete: Cascade)
  
  @@index([weeklyFeedbackId])
  @@index([date])
  @@index([swimmerId])
  @@unique([swimmerId, date])
}

// Coach-initiated feedback reminder
model FeedbackReminder {
  id               String   @id @default(cuid())
  message          String   // Coach's message/instruction
  targetSwimmerIds Json?    // JSON array of swimmer IDs, null = entire team
  targetGroup      String?  // Optional group filter
  periodStart      String   // Start date YYYY-MM-DD
  periodEnd        String   // End date YYYY-MM-DD
  
  createdAt        DateTime @default(now())
  
  responses        TargetedFeedback[]
  
  @@index([createdAt])
}

// Athlete response to a coach feedback reminder
model TargetedFeedback {
  id          String   @id @default(cuid())
  reminderId  String
  swimmerId   String
  content     String   // Athlete's feedback text
  rpe         Int?     // Optional RPE
  soreness    Int?     // Optional soreness
  coachReply  String?  // Coach's reply to this specific response
  repliedAt   String?  // ISO date when coach replied
  
  createdAt   DateTime @default(now())
  
  reminder    FeedbackReminder @relation(fields: [reminderId], references: [id], onDelete: Cascade)
  swimmer     Swimmer  @relation(fields: [swimmerId], references: [id], onDelete: Cascade)
  
  @@index([reminderId])
  @@index([swimmerId])
  @@unique([reminderId, swimmerId])
}

// ==========================================
// Coach Announcements (Moments Feed)
// ==========================================

model CoachAnnouncement {
  id             String   @id @default(cuid())
  targetSwimmerIds Json?  // JSON array of swimmer IDs, null = all
  targetGroup    String?  // Optional group filter e.g. "Advanced"
  createdAt      DateTime @default(now())
  isStarred      Boolean  @default(false)

  blocks         AnnouncementBlock[]

  @@index([createdAt])
  @@index([targetGroup])
}

model AnnouncementBlock {
  id              String   @id @default(cuid())
  announcementId  String
  type            String   // "text" | "image" | "video" | "link"
  content         String   // text body, R2 URL, or external URL
  sortOrder       Int      @default(0)
  thumbnailUrl    String?  // for video thumbnails

  announcement    CoachAnnouncement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@index([announcementId])
}

// ==========================================
// Meet Management (比赛管理)
// ==========================================

model Meet {
  id          String   @id @default(cuid())
  name        String   // e.g. "2026春季锦标赛"
  date        String   // YYYY-MM-DD
  time        String?  // HH:MM (precise start time for countdown)
  location    String?
  description String?
  isActive    Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([date])
}

// ==========================================
// Avatar Shop & Economy (虚拟商城)
// ==========================================

model ShopItem {
  id          String   @id @default(cuid())
  name        String   // e.g. "奥运金牌冠军泳帽"
  category    String   // Display category
  tier        String   // "basic"|"entry"|"advanced"|"premium"|"legendary"|"ultimate"
  price       Int      // XP cost
  imageKey    String   // Asset key/path for the sprite layer PNG
  slotType    String   // "head"|"eyes"|"body"|"lower"|"feet"|"hand"|"background"
  gender      String   @default("unisex") // "male"|"female"|"unisex"
  sortOrder   Int      @default(0)
  
  createdAt   DateTime @default(now())
  
  @@index([tier])
  @@index([slotType])
  @@index([gender])
}

// ==========================================
// XP Transaction Ledger (经验值流水)
// ==========================================

model XpTransaction {
  id            String   @id @default(cuid())
  swimmerId     String
  amount        Int      // Positive = earned, Negative = spent
  source        String   // "attendance"|"feedback"|"streak"|"buddy"|"coach_reward"|"milestone"|"pb"|"purchase"|"levelup"|"starter_pack"
  description   String?  // Human-readable note
  balanceAfter  Int      // Snapshot of balance after this transaction
  totalXpAfter  Int      // Snapshot of totalXp after this transaction
  
  createdAt     DateTime @default(now())
  
  swimmer       Swimmer  @relation(fields: [swimmerId], references: [id], onDelete: Cascade)
  
  @@index([swimmerId])
  @@index([createdAt])
  @@index([source])
}

// ==========================================
// Buddy System (死党系统)
// ==========================================

model BuddyPair {
  id          String   @id @default(cuid())
  swimmer1Id  String
  swimmer2Id  String
  status      String   @default("pending") // "pending"|"active"|"dissolved"
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  swimmer1    Swimmer  @relation("BuddySwimmer1", fields: [swimmer1Id], references: [id], onDelete: Cascade)
  swimmer2    Swimmer  @relation("BuddySwimmer2", fields: [swimmer2Id], references: [id], onDelete: Cascade)
  
  @@unique([swimmer1Id, swimmer2Id])
  @@index([swimmer1Id])
  @@index([swimmer2Id])
}

// ==========================================
// Activity Feed (活动通知流)
// ==========================================

model ActivityFeedItem {
  id          String   @id @default(cuid())
  swimmerId   String
  type        String   // "xp_earned"|"coach_reward"|"buddy_sync"|"milestone"|"levelup"|"meet_reminder"|"purchase"
  title       String   // e.g. "教练为你打赏了 300 XP！"
  detail      String?  // Optional extra text
  xpAmount    Int?     // XP amount involved (if any)
  isRead      Boolean  @default(false)
  
  createdAt   DateTime @default(now())
  
  swimmer     Swimmer  @relation(fields: [swimmerId], references: [id], onDelete: Cascade)
  
  @@index([swimmerId])
  @@index([createdAt])
}
